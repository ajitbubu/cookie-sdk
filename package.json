{
  "name": "@ajitbubu/cookie-banner-sdk",
  "version": "0.1.0",
  "description": "Drop-in cookie consent banner SDK with Google Consent Mode v2 signaling. Shadow-DOM isolated, zero runtime deps.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/cookie-consent.cjs",
  "module": "./dist/cookie-consent.js",
  "types": "./dist/cookie-consent.d.ts",
  "unpkg": "./dist/cookie-consent.global.js",
  "jsdelivr": "./dist/cookie-consent.global.js",
  "exports": {
    ".": {
      "types": "./dist/cookie-consent.d.ts",
      "import": "./dist/cookie-consent.js",
      "require": "./dist/cookie-consent.cjs"
    },
    "./bootstrap": "./dist/cc-bootstrap.global.js",
    "./standalone": "./dist/cookie-consent.standalone.global.js",
    "./faceoff": "./dist/cookie-consent.faceoff.global.js",
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "build": "tsup",
    "build:sites": "node scripts/build-sites.mjs",
    "builder": "node scripts/builder-server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cookie",
    "consent",
    "gdpr",
    "consent-mode",
    "gtm",
    "banner"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
