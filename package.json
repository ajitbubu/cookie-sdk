{
  "name": "cookie-banner-sdk",
  "version": "0.1.0.0",
  "description": "Drop-in cookie consent banner SDK with Google Consent Mode v2 signaling. Shadow-DOM isolated, zero runtime deps.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/cookie-consent.js",
      "require": "./dist/cookie-consent.umd.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cookie",
    "consent",
    "gdpr",
    "consent-mode",
    "gtm",
    "banner"
  ],
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
